<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>zh_CN</string>
    <key>CFBundleExecutable</key>
    <string>RemoteVoiceInputMethod</string>
    <key>CFBundleIdentifier</key>
    <string>com.remotevoice.inputmethod</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>RemoteVoice 输入法</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1</string>
    <key>LSBackgroundOnly</key>
    <true/>
    <key>LSUIElement</key>
    <true/>

    <!-- InputMethodKit 注册键 -->
    <key>InputMethodConnectionName</key>
    <string>RVInputMethod_Connection</string>
    <key>InputMethodServerControllerClass</key>
    <string>RVInputController</string>

    <!-- 输入模式声明：现代 IMKit/.app 输入法由 ComponentInputModeDict 注册，
         系统据此在「系统设置 → 键盘 → 输入法」里枚举出可添加的输入法；
         旧的 Carbon component 键（tsInputMethodCharacteristicsFile 等）对 .app 路径无效。 -->
    <key>ComponentInputModeDict</key>
    <dict>
        <key>tsInputModeListKey</key>
        <dict>
            <key>com.remotevoice.inputmethod.mode</key>
            <dict>
                <key>TISInputSourceID</key>
                <string>com.remotevoice.inputmethod.mode</string>
                <key>tsInputModeAlternateMenuTitleKey</key>
                <string>RemoteVoice 输入法</string>
                <key>tsInputModeCharacterRepertoireKey</key>
                <array>
                    <string>Hans</string>
                </array>
                <key>tsInputModeIsVisibleKey</key>
                <true/>
                <key>tsInputModeKeyEquivalentModifiersKey</key>
                <integer>0</integer>
                <key>tsInputModeKeyEquivalentKey</key>
                <string></string>
                <key>tsInputModePrimaryInScriptKey</key>
                <true/>
                <key>tsInputModeScriptKey</key>
                <string>smUnicodeScript</string>
                <key>TISIntendedLanguage</key>
                <string>zh-Hans</string>
            </dict>
        </dict>
        <key>tsVisibleInputModeOrderedArrayKey</key>
        <array>
            <string>com.remotevoice.inputmethod.mode</string>
        </array>
    </dict>
</dict>
</plist>
