# 飞书机器人「远程语音」监听器配置
# 复制为 .env 后填写真实值。.env 不入库。
# App ID / App Secret 来自你自己创建的飞书应用（见根目录 REPRODUCE.md 第 5 步）。

FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=

# 你自己部署的 Cloudflare Worker 中继的 /ws 地址
RELAY_URL=wss://<your-worker>.workers.dev/ws

# 目标 Mac 的永久 macId（启动 Mac App 后：defaults read com.remotevoice.input rv.macId）
MAC_ID=

# 在 Mac 设备列表里显示的名字
DEVICE_NAME=飞书远程语音
