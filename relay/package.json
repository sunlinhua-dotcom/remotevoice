{
  "name": "remotevoice-relay",
  "version": "0.1.0",
  "private": true,
  "description": "RemoteVoice cloud relay: pairing + Doubao streaming ASR + LLM post-processing",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "e2e:pair": "node scripts/e2e-pair.mjs",
    "e2e:asr": "node --import tsx scripts/e2e-asr.mjs",
    "e2e:llm": "node --import tsx scripts/e2e-llm.mjs"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
