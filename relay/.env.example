# RemoteVoice relay 配置
# 复制为 .env 后填写真实值；.env 不入库。

# ---- 服务监听 ----
PORT=8787
# 静态站点目录（手机 PWA），相对 relay 目录。留空则不托管。
WEB_DIR=../web

# ---- 豆包流式语音识别（语音服务） ----
# 注意：语音服务的 Access Token 与方舟 Ark Key 是两套凭证。
DOUBAO_ASR_APP_ID=your_app_id
DOUBAO_ASR_ACCESS_TOKEN=your_access_token
DOUBAO_ASR_SECRET_KEY=your_secret_key
# 豆包大模型流式 ASR 的 wss 端点（以官方文档为准；占位，实现时核对）。
DOUBAO_ASR_WSS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel

# ---- 火山方舟 Ark（LLM 后处理 doubao-seed-2-0-lite） ----
# 与语音 Access Token 不同，需在方舟控制台单独获取；P4 前提供。
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-lite-260215

# ---- 配对与会话 ----
PAIR_CODE_TTL_MS=300000
MAX_SESSION_MS=120000
